# MissionForge — Environment Variables
# Copy this file to .env and fill in your values

# App
SECRET_KEY=change-me-to-a-random-32-char-string
DEBUG=true
APP_NAME=MissionForge
CORS_ORIGINS=["http://localhost:3000"]

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./missionforge.db
# DATABASE_URL=postgresql+asyncpg://mf:mf@localhost:5432/missionforge

# ChromaDB (vector store for RAG + memory)
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_PREFIX=mf

# Missions
MISSIONS_DIR=./missions

# LLM Providers (leave empty to skip tier in fallback chain)
# Tier LOCAL — Ollama (free, local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# Tier FAST — Cerebras (free tier)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=qwen-3-32b

# Tier FAST2 — Google Gemini (free tier)
GOOGLE_AI_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash-lite

# Tier FAST3 — Groq (free tier, rate-limited)
GROQ_API_KEY=

# Tier MID — Mistral (low cost)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Tier STRATEGIC — Anthropic Claude (highest quality)
ANTHROPIC_API_KEY=

# Security — whitelist env vars accessible in YAML mission templates
ALLOWED_ENV_VARS=["SLACK_WEBHOOK","DISCORD_WEBHOOK"]
