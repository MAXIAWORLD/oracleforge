# LLMForge — Environment Variables
SECRET_KEY=change-me-to-a-random-32-char-string
DEBUG=true
DATABASE_URL=sqlite+aiosqlite:///./llmforge.db
CORS_ORIGINS=["http://localhost:3000"]

# Cache
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
CACHE_MAX_ENTRIES=1000

# Budget caps (0 = unlimited)
DAILY_BUDGET_USD=0
PER_KEY_DAILY_BUDGET_USD=0

# LLM Providers
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
CEREBRAS_API_KEY=
CEREBRAS_MODEL=qwen-3-32b
GOOGLE_AI_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash-lite
GROQ_API_KEY=
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
ANTHROPIC_API_KEY=
