# GuardForge Dashboard — environment variables
#
# Server-side only (NOT exposed to the browser).
# The dashboard never talks to the backend directly from client code;
# it always goes through the Next.js route handler at app/api/[...path]/route.ts
# which forwards the request server-side with the API key.
#
# Copy to .env.local for local dev, or .env.production for prod build.

# URL of the GuardForge backend (FastAPI on port 8004 by default)
GUARDFORGE_BACKEND_URL=http://127.0.0.1:8004

# Backend SECRET_KEY — used by the proxy to authenticate against /api/*
# MUST match SECRET_KEY in backend/.env / /opt/guardforge/secrets/.env.production
GUARDFORGE_API_KEY=change-me-to-match-backend-SECRET_KEY
