# GuardForge — Environment Variables
# Copy this file to .env and fill in the values

# REQUIRED in production
VAULT_ENCRYPTION_KEY=           # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Optional
SECRET_KEY=change-me-to-a-random-32-char-string
DEBUG=true                      # Set to false in production
DATABASE_URL=sqlite+aiosqlite:///./data/guardforge.db
CORS_ORIGINS=["http://localhost:3003","http://localhost:3000"]
PII_CONFIDENCE_THRESHOLD=0.7
PII_LANGUAGES=["en","fr"]
DEFAULT_POLICY=strict
