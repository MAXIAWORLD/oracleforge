# MAXIA Oracle — environment variables template
#
# Copy this to `backend/.env` and fill in whichever keys you have.
# DO NOT commit the real `.env` file (it is in the root .gitignore).

# ══════════════════════════════════════════════════════════════════════════
# REQUIRED (app refuses to start if absent or invalid)
# ══════════════════════════════════════════════════════════════════════════

# Execution environment. Must be one of: dev, staging, prod.
ENV=dev

# ── REQUIRED in staging / prod, OPTIONAL in dev ──

# Server-side pepper mixed into SHA256(api_key + pepper). Must be >= 32 chars.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
API_KEY_PEPPER=

# SQLite database path. Default in dev: ./maxia_oracle.db
# In prod set an absolute path on a persistent mount.
DB_PATH=

# Public Base-mainnet address that receives x402 payments (Phase 4).
# Format: ^0x[a-fA-F0-9]{40}$ (42 chars total, 0x prefix + 40 hex).
# NEVER set a private key here — only the public address. Funds are
# withdrawn manually to cold storage on a weekly basis.
X402_TREASURY_ADDRESS_BASE=

# Python logging level. Defaults: dev=INFO, staging/prod=WARNING
LOG_LEVEL=

# ══════════════════════════════════════════════════════════════════════════
# OPTIONAL (modules degrade gracefully to public free endpoints)
# ══════════════════════════════════════════════════════════════════════════

# ── Solana RPC (consumed by services.oracle.price_oracle) ──
# Priority order: Chainstack > Alchemy > Helius > custom > public fallbacks.
HELIUS_API_KEY=
CHAINSTACK_RPC=
ALCHEMY_SOLANA_KEY=
SOLANA_RPC=

# ── Base mainnet RPC (consumed by services.oracle.chainlink_oracle) ──
# Default: https://mainnet.base.org (public, rate-limited)
BASE_RPC_URL=

# ── Pyth Hermes endpoint (consumed by services.oracle.pyth_oracle) ──
# Default: https://hermes.pyth.network (public)
PYTH_HERMES_URL=

# ── Finnhub (equity fallback in pyth_oracle.get_stock_price) ──
# Free tier: 60 req/min. Optional — without it, the cascade skips to Yahoo.
FINNHUB_API_KEY=

# ══════════════════════════════════════════════════════════════════════════
# ── x402 Base mainnet payment configuration (Phase 4) ──
# ══════════════════════════════════════════════════════════════════════════

# Coinbase x402 facilitator URL. MUST be HTTPS in staging/prod.
# Default: https://x402.org/facilitator
X402_FACILITATOR_URL=

# Minimum USDC amount accepted on a single x402 call.
# Default: 0.001 (matches the single-call price in X402_PRICE_MAP).
# Keeps sanity against accidentally-configured-too-low prices.
BASE_MIN_TX_USDC=
