{
  "name": "eliza-plugin-maxia-oracle",
  "version": "0.4.0",
  "description": "ElizaOS plugin for the MAXIA Oracle price feed. Data feed only. Not investment advice. No custody. No KYC.",
  "license": "Apache-2.0",
  "author": "MAXIA <ceo@maxiaworld.app>",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "maxia",
    "oracle",
    "eliza",
    "elizaos",
    "ai-agents",
    "price-feed",
    "crypto",
    "solana",
    "plugin"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@maxia/oracle": "file:../../sdk/typescript"
  },
  "peerDependencies": {
    "@elizaos/core": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@elizaos/core": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "homepage": "https://oracle.maxiaworld.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxiaworld/oracleforge.git",
    "directory": "plugins/eliza-plugin-maxia-oracle"
  }
}
