# OracleForge — Environment Variables
SECRET_KEY=change-me-to-a-random-32-char-string
DEBUG=true
DATABASE_URL=sqlite+aiosqlite:///./oracleforge.db
CORS_ORIGINS=["http://localhost:3000"]

# Cache TTL
PRICE_CACHE_TTL=30
STOCK_CACHE_TTL=60

# Sources
COINGECKO_ENABLED=true
PYTH_ENABLED=true
PYTH_HERMES_URL=https://hermes.pyth.network
CHAINLINK_ENABLED=true
BASE_RPC_URL=https://mainnet.base.org
FINNHUB_API_KEY=
FINNHUB_ENABLED=false
YAHOO_ENABLED=true

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_TTL=60
