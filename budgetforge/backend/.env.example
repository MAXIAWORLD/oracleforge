# BudgetForge Backend Environment Variables

# App Configuration
APP_ENV=development
APP_URL=http://localhost:8011
ADMIN_API_KEY=your-admin-api-key-here
PORTAL_SECRET=your-portal-secret-here

# Database
DATABASE_URL=sqlite:///./budgetforge.db
REDIS_URL=redis://localhost:6379

# Provider API Keys
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_API_KEY=your-google-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
TOGETHER_API_KEY=your-together-api-key
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com
AWS_BEDROCK_ACCESS_KEY=your-aws-access-key
AWS_BEDROCK_SECRET_KEY=your-aws-secret-key
AWS_BEDROCK_REGION=us-east-1

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434

# SMTP Configuration (optional - for email alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_FROM_EMAIL=alerts@yourdomain.com