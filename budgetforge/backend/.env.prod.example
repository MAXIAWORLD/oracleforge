# BudgetForge — PRODUCTION environment
# Copy to .env on VPS: /opt/budgetforge/backend/.env
# Generate secrets: python3 -c "import secrets; print(secrets.token_hex(32))"

APP_ENV=production
APP_URL=https://budgetforge.yourdomain.com
ADMIN_API_KEY=<generate-strong-secret>
PORTAL_SECRET=<generate-strong-secret>
SECRET_KEY=<generate-strong-secret>
ADMIN_EMAIL=your@email.com

# Database (SQLite path relative to WorkingDirectory = /opt/budgetforge/backend)
DATABASE_URL=sqlite:///./budgetforge.db
# Redis not required unless you enable distributed locking
# REDIS_URL=redis://127.0.0.1:6379

# Provider API Keys — add only the providers you offer
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=

# Ollama — only if running on same host
# OLLAMA_BASE_URL=http://localhost:11434

# SMTP — required for budget alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@yourdomain.com
SMTP_PASSWORD=<gmail-app-password>
ALERT_FROM_EMAIL=alerts@yourdomain.com

# Stripe (Bloc 6 — leave empty until keys obtained)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
